# Contact form email delivery (Resend — https://resend.com)
# Copy to .env.local and fill in. Without these, the contact form runs in
# "not configured" mode (see src/app/api/contact/route.ts for the policy).

# API key from the Resend dashboard.
RESEND_API_KEY=

# Verified sender address on your Resend domain, e.g. "Blanc Nails <hello@yourdomain.com>".
CONTACT_FROM_EMAIL=

# Where submissions are delivered. Defaults to site.contact.email if unset.
CONTACT_TO_EMAIL=
