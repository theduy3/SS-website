# Contact form email delivery (Resend — https://resend.com)
# Copy to .env.local and fill in. Without these, the contact form runs in
# "not configured" mode (see src/app/api/contact/route.ts for the policy).

# API key from the Resend dashboard.
RESEND_API_KEY=

# Verified sender address on your Resend domain, e.g. "Blanc Nails <hello@yourdomain.com>".
CONTACT_FROM_EMAIL=

# Where submissions are delivered. Defaults to site.contact.email if unset.
CONTACT_TO_EMAIL=

# Optional: URL of the owner's app endpoint returning the pop-up array
# (see tasks/spec-popup-widget-system.md for the contract). Unset = local
# src/data/popups.json fallback is used.
POPUP_SOURCE_URL=

# Google Business Profile API — used only by scripts/fetch-google-reviews.mjs
# (build-time fetch of real 5★ reviews; NOT needed at deploy/runtime). OAuth2
# refresh-token flow, scope https://www.googleapis.com/auth/business.manage.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# From the My Business v4 account/location resource names (the numeric IDs).
GOOGLE_BUSINESS_ACCOUNT_ID=
GOOGLE_BUSINESS_LOCATION_ID=
